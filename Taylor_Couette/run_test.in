&parameters_cube
na = 192 , 
nz = 48 ,
nr = 64 ,
r_min = 1.0,
r_max = 3.0,
z_min = 0.0 ,
z_max = 1.0 ,  
nb_cpu_y = 8 ,
nb_cpu_z = 4
/


&parameters_physical
RE = 1000 ,
EPS = 1E-2
/

&parameters_initial_condition
na0 = 2 ,
nz0 = 2 ,
nr0 = 2 ,
/

&parameters_timescheme
tmax = 1E-3 ,
dt = 1e-5 ,
root_dir = 'outdir/'
resume = F,
/

&parameters_diagnostics
snap_dir = 'snapshots/'
dn_snap = 100,
init_file = 'cond_init/init_1.h5'
/


