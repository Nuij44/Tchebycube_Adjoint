&parameters_cube
na = 64 , 
nz = 64 ,
nr = 64 ,
r_min = 1.0,
r_max = 3.0,
z_min = 0.0 ,
z_max = 1.0 ,  
nb_cpu_y = 8 ,
nb_cpu_z = 4
/


&parameters_physical
RE = 1 ,
EPS = 1E-7
/

&parameters_initial_condition
