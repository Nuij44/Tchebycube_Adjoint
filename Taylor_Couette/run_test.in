nz0 = 2 ,
nr0 = 2 ,
/

&parameters_timescheme
tmax = 1 ,
dt = 0.03125E-2 ,
root_dir = 'outdir/'
resume = F,
/

&parameters_diagnostics
snap_dir = 'snapshots/'
dn_snap = 100,
init_file = '1Z_RE_1000_HR/cond_init/init_5.h5'
/


