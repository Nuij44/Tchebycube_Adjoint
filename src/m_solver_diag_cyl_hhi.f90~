  SUBROUTINE SOLVER_DIAG_CYL_HHI_SET_BVS(THIS,MESH,AXIS,UDF_MINUS,UDF_PLUS)
    use decomp_2d
    use m_mesh_base
    use mpi
    IMPLICIT NONE
    CLASS(T_SOLVER_DIAG_CYL_HHI) :: THIS
    TYPE(T_MESH_BASE)             :: MESH(3)
    INTEGER                       :: AXIS
    PROCEDURE(UDF_TIMESPACE)      :: UDF_PLUS
    PROCEDURE(UDF_TIMESPACE)      :: UDF_MINUS
      
    TYPE(DECOMP_INFO) :: PH
    REAL(KIND=8) :: TIME
    integer :: ierr
      
    CALL GET_DECOMP_INFO(PH)
    
    
    if (axis==3) then
       
       CALL SOLVER_DIAG_HHI_SET_BOUNDARY_FIELD(&
            MESH(1)%X, MESH(2)%X, MESH(3)%X, &
            UDF_MINUS,UDF_PLUS,THIS%BC_VAL_L_Z,THIS%BC_VAL_R_Z,PH%XST,PH%XEN,PH%YST,PH%YEN,PH%ZST,PH%ZEN)
    else
       
       call MPI_Abort(mpi_comm_world,0,ierr)
    end if
  end subroutine SOLVER_DIAG_CYL_HHI_SET_BVS

