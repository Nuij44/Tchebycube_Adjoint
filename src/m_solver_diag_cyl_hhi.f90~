       lbdy, ny, yst, yen, &
       lbdz, nz, zst, zen, pz, pzm1, clz,ccz, fzl, fzr, bvzl, bvzr)
    use m_fourier_transform
    use decomp_2d
    implicit none
    real(kind=8) :: sigma
    integer :: nx,xst(3),xen(3)
    integer :: ny,yst(3),yen(3)
    integer :: nz,zst(3),zen(3)
    real(kind=8), dimension(xst(1):xen(1),xst(2):xen(2),xst(3):xen(3) ) :: fi,sfi
    complex(kind=8), dimension( 1:nx+1 ) :: lbdx 
    complex(kind=8), dimension( 1:ny+1 ) :: lbdy
    complex(kind=8), dimension( 1:nz+1 , zst(1):zen(1) ) :: lbdz
    
    complex(kind=8), dimension( 1:nz+1,1:nz+1, zst(1):zen(1)  ) :: pz,pzm1

    complex(kind=8), dimension(1:nz+1,1:2) :: ccz
    real(kind=8)::clz(2,2)
    real(kind=8), dimension(1:nz+1) :: fzl,fzr
    real(kind=8), dimension(xst(1):xen(1),xst(2):xen(2)) :: bvzl
    real(kind=8), dimension(xst(1):xen(1),xst(2):xen(2)) :: bvzr
    integer :: i,j,k
        
    forall(i=xst(1):xen(1),j=xst(2):xen(2),k=xst(3):xen(3))
       dg_x(i,j,k) = sfi(i,j,k) - (fzl(k)*bvzl(i,j) + fzr(k)*bvzr(i,j))
    end forall
    
    DO K = ZST(3),ZEN(3)
       DO J = ZST(2),ZEN(2) 
          DO I=ZST(1),ZEN(1)
             LBD(I,J,K) = ( lbdz(k,i) +  lbdy(j) + sigma )**(-1)
             IF (K==   1) LBD(I,J,K) = 1
             IF (K==NZ+1) LBD(I,J,K) = 1
          END DO
       END DO
    END DO
    
    if (xst(3)==1) then
       forall(i=xst(1):xen(1),j=xst(2):xen(2))
          dg_x(i,j,   1) = bvzl(i,j)
       end forall
    end if

    
    if (xen(3)==nz+1) then
       forall(i=xst(1):xen(1),j=xst(2):xen(2))
          dg_x(i,j,nz+1) = bvzr(i,j)
       end forall
    end if

    
    call c2c_1m_x(dg_x,plan_fwd_x)
    call transpose_x_to_y(dg_x, zg1_y)
    call c2c_1m_y(zg1_y,plan_fwd_y)
    call transpose_y_to_z(zg1_y,zg1_z)

    !call tensor_product_k(pzm1,zg1_z,zg2_z,zst,zen)
    CALL TENSOR_PRODUCT_KK(pzm1, zg1_z, zg2_z, ZST, ZEN)

    
    forall(i=zst(1):zen(1),j=zst(2):zen(2),k=zst(3):zen(3))
       zg1_z(i,j,k) = zg2_z(i,j,k) * LBD(i,j,k)
    end forall
    
    
    !call tensor_product_k(pz,zg1_z,zg2_z,zst,zen)
    CALL TENSOR_PRODUCT_KK(pz, zg1_z, zg2_z, ZST, ZEN)
    call tensor_product_k_cl(ccz, zg2_z, dg_cl_z, zst, zen , nz )

    forall(i=zst(1):zen(1),j=zst(2):zen(2))
       zg2_z(i,j,   1) = dg_cl_z(i,j,1)*clz(1,1) + dg_cl_z(i,j,2)*clz(1,2)
       zg2_z(i,j,nz+1) = dg_cl_z(i,j,1)*clz(2,1) + dg_cl_z(i,j,2)*clz(2,2)
    end forall

    
    call transpose_z_to_y(zg2_z,zg1_y)
    call c2c_1m_y(zg1_y,plan_bck_y)
    call transpose_y_to_x(zg1_y,dg_x)
    call c2c_1m_x(dg_x,plan_bck_x)
    
    forall(i=xst(1):xen(1),j=xst(2):xen(2),k=xst(3):xen(3))
       fi(i,j,k) = dg_x(i,j,k)
    end forall
  end subroutine solver_diag_cyl_hhi_solve




  subroutine solver_diag_cyl_hhi_solve_poisson(fi,sfi,&
       nux,lbdx, nx, xst, xen, &
       nuy,lbdy, ny, yst, yen, &
       nuz,lbdz, nz, zst, zen, pz, pzm1, clz,ccz, fzl, fzr, bvzl, bvzr)
    use m_fourier_transform
    use decomp_2d
    implicit none
    real(kind=8) :: nux,nuy,nuz
    integer :: nx,xst(3),xen(3)
    integer :: ny,yst(3),yen(3)
    integer :: nz,zst(3),zen(3)
    real(kind=8), dimension(xst(1):xen(1),xst(2):xen(2),xst(3):xen(3) ) :: fi,sfi
    complex(kind=8), dimension( 1:nx+1 ) :: lbdx 
    complex(kind=8), dimension( 1:ny+1 ) :: lbdy
    complex(kind=8), dimension( 1:nz+1 ) :: lbdz
    
    complex(kind=8), dimension( 1:nz+1,1:nz+1 ) :: pz,pzm1

    complex(kind=8), dimension(1:nz+1,1:2) :: ccz
    real(kind=8)::clz(2,2)
    real(kind=8), dimension(1:nz+1) :: fzl,fzr
    real(kind=8), dimension(xst(1):xen(1),xst(2):xen(2)) :: bvzl
    real(kind=8), dimension(xst(1):xen(1),xst(2):xen(2)) :: bvzr
    integer :: i,j,k,ierr

    
!!$    forall(i=xst(1):xen(1),j=xst(2):xen(2),k=xst(3):xen(3))
!!$       dg_x(i,j,k) = sfi(i,j,k)  - (fzl(k)*bvzl(i,j) + fzr(k)*bvzr(i,j))
!!$    end forall

    

    print*,"solver_diag_cyl_hhi_solve_poisson"
    call mpi_finalize(ierr)
    stop
    dg_x = sfi 
    
    DO K = ZST(3),ZEN(3)
       DO J = ZST(2),ZEN(2) 
          DO I=ZST(1),ZEN(1)
             LBD(I,J,K) = ( nux*lbdx(i) + nuy*lbdy(j) +  nuz*lbdz(k)  )**(-1)

             IF (K==   1) LBD(I,J,K) = 1
             IF (K==NZ+1) LBD(I,J,K) = 1
          END DO
       END DO
    END DO
    
    if (xst(3)==1) then
       forall(i=xst(1):xen(1),j=xst(2):xen(2))
          dg_x(i,j,   1) = bvzl(i,j)
       end forall
    end if

    
    if (xen(3)==nz+1) then
       forall(i=xst(1):xen(1),j=xst(2):xen(2))
          dg_x(i,j,nz+1) = bvzr(i,j)
       end forall
    end if

    
    call c2c_1m_x(dg_x,plan_fwd_x)
    call transpose_x_to_y(dg_x, zg1_y)
    call c2c_1m_y(zg1_y,plan_fwd_y)
    call transpose_y_to_z(zg1_y,zg1_z)
    call tensor_product_k(pzm1,zg1_z,zg2_z,zst,zen)

    
    forall(i=zst(1):zen(1),j=zst(2):zen(2),k=zst(3):zen(3))
       zg1_z(i,j,k) = zg2_z(i,j,k) * LBD(i,j,k)
    end forall
    
    
    call tensor_product_k(pz,zg1_z,zg2_z,zst,zen)
    call tensor_product_k_cl(ccz, zg2_z, dg_cl_z, zst, zen , nz )

    forall(i=zst(1):zen(1),j=zst(2):zen(2))
       zg2_z(i,j,   1) = dg_cl_z(i,j,1)*clz(1,1) + dg_cl_z(i,j,2)*clz(1,2)
       zg2_z(i,j,nz+1) = dg_cl_z(i,j,1)*clz(2,1) + dg_cl_z(i,j,2)*clz(2,2)
    end forall

    
    call transpose_z_to_y(zg2_z,zg1_y)
    call c2c_1m_y(zg1_y,plan_bck_y)
    call transpose_y_to_x(zg1_y,dg_x)
    call c2c_1m_x(dg_x,plan_bck_x)
    
    forall(i=xst(1):xen(1),j=xst(2):xen(2),k=xst(3):xen(3))
       fi(i,j,k) = dg_x(i,j,k)
    end forall
  end subroutine solver_diag_cyl_hhi_solve_poisson
  
  SUBROUTINE TENSOR_PRODUCT_KK(DZ, FI, DFI, ZST, ZEN)
    IMPLICIT NONE
    INTEGER         :: ZST(3), ZEN(3)
    COMPLEX(KIND=8) :: DZ(ZST(3):ZEN(3), ZST(3):ZEN(3), ZST(1):ZEN(1))
    COMPLEX(KIND=8) :: FI(ZST(1):ZEN(1), ZST(2):ZEN(2), ZST(3):ZEN(3))
    COMPLEX(KIND=8) :: DFI(ZST(1):ZEN(1), ZST(2):ZEN(2), ZST(3):ZEN(3))
    COMPLEX(KIND=8) :: ALPHA, BETA
    INTEGER :: I, N(3), NI, NJ, NK,info

    
    
    ! Paramètres DGEMM
    ALPHA = 1D0
    BETA = 0D0
    
    ! Dimensions locales
    N = ZEN - ZST + 1
    NI = N(1)
    NJ = N(2)
    NK = N(3)
    
    DO I=ZST(1),ZEN(1)
       CALL ZGEMM('N','T',NJ,NK,NK, ALPHA, FI(I,ZST(2):ZEN(2),ZST(3):ZEN(3)), NJ , &
            DZ(ZST(3):ZEN(3),ZST(3):ZEN(3),I) , NK , BETA , DFI(I,ZST(2):ZEN(2),ZST(3):ZEN(3)), NJ )
    end DO
    
  END SUBROUTINE TENSOR_PRODUCT_KK
  

  SUBROUTINE TENSOR_PRODUCT_K(DZ, FI, DFI, ZST, ZEN)
    IMPLICIT NONE
    INTEGER         :: ZST(3), ZEN(3)
    complex(KIND=8) :: DZ(ZST(3):ZEN(3), ZST(3):ZEN(3), ZST(1):ZEN(1))
    complex(KIND=8) :: FI(ZST(1):ZEN(1), ZST(2):ZEN(2), ZST(3):ZEN(3))
    complex(KIND=8) :: DFI(ZST(1):ZEN(1), ZST(2):ZEN(2), ZST(3):ZEN(3))
    complex(KIND=8) :: ALPHA, BETA
    INTEGER :: I, N(3), NI, NJ, NK,info
    
    ! Paramètres DGEMM
    ALPHA = 1D0
    BETA = 0D0
    
    ! Dimensions locales
    N = ZEN - ZST + 1
    NI = N(1)
    NJ = N(2)
    NK = N(3)
    
    
    CALL ZGEMM('N','T',NI*NJ,NK,NK, ALPHA, FI, NI*NJ , DZ, NK , BETA , DFI, NI*NJ )
    
  END SUBROUTINE TENSOR_PRODUCT_K
  

  
  SUBROUTINE TENSOR_PRODUCT_K_CL(CC,FI,DFI,ZST,ZEN,NZ)
    IMPLICIT NONE
    INTEGER :: ZST(3),ZEN(3),NZ
    complex(kind=8) :: CC(1:2,1:NZ+1)
    complex(kind=8) ::  FI(ZST(1):ZEN(1),ZST(2):ZEN(2),ZST(3):ZEN(3))
    complex(kind=8) :: DFI(ZST(1):ZEN(1),ZST(2):ZEN(2),1:2)
    
    INTEGER :: N(3),NI,NJ,NK
    complex(kind=8) ::  ALPHA,BETA
    
    ALPHA = 1d0
    BETA = 0d0
    N = ZEN - ZST + 1
    NI = N(1)
    NJ = N(2)
    NK = N(3) ! NZ + 1 car Z-pencil
    CALL ZGEMM('N','T',NI*NJ,2,NK, ALPHA, FI, NI*NJ , CC, 2 , BETA , DFI, NI*NJ )
    
  END SUBROUTINE TENSOR_PRODUCT_K_CL

  !indice Fortran --> fréquence k (1-indexé)
  function index_to_freq_c2c(idx, N) result(k)
    implicit none
    integer, intent(in) :: idx, N
    integer :: k
    
    if (idx <= N/2 + 1) then
       k = idx - 1
    else
       k = idx - 1 - N
    end if
    
  end function index_to_freq_c2c


  ! Fréquence k --> indice Fortran (1-indexé)
  function freq_to_index_c2c(k, N) result(idx)
    implicit none
    integer, intent(in) :: k, N
    integer :: idx
    
    if (k >= 0) then
       idx = k + 1
    else
       idx = k + N + 1
    end if
    
  end function freq_to_index_c2c
  

  
