  subroutine solver_diag_hhi_build_svv(this,&
       x, nux, nx, xst, xen, &
       y, nuy, ny, yst, yen, &
         z, nuz, nz, zst, zen, d2z, dz, cl_left_z, cl_right_z,alpha,beta )
    use decomp_2d_mpi
    implicit none
    class(t_solver_diag_cyl_hhi) :: this
    integer :: nx,xst(3),xen(3)
    REAL(KIND=8) :: x(nx+1),nux
      
    integer :: ny,yst(3),yen(3)
    REAL(KIND=8) :: y(ny+1),nuy
      
    integer :: nz,zst(3),zen(3)
    REAL(KIND=8) :: z(nz+1),nuz,d2z(1:nz+1,1:nz+1),dz(1:nz+1,1:nz+1)
    REAL(KIND=8) :: cl_left_z(2), cl_right_z(2)
      
    real(kind=8) :: pi=acos(-1.),alpha,beta
    real(kind=8) :: xmin,xmax,hx,lx,wx
    real(kind=8) :: ymin,ymax,hy,ly,wy
      
    integer :: nxp,nyp,nzp
      
    integer :: i,im,jm,j,k

    real(kind=8),allocatable :: d2(:,:),r(:,:),rm1(:,:),rm2(:,:),bl(:,:),br(:,:),id(:,:)
    
    REAL(KIND=8), dimension(:,:,:), allocatable :: PZ,PZM1
    REAL(KIND=8), dimension(:,:)  , allocatable :: LBDZ
    COMPLEX(KIND=8), dimension(:,:)  , allocatable :: LBDZ_
    REAL(KIND=8), dimension(:,:)  , allocatable :: FLZ,FRZ
    REAL(KIND=8), dimension(:,:)  , allocatable :: CCZ,SVV_TCHEBY,M,T,Q
    REAL(KIND=8), dimension(:), allocatable :: C
    REAL(KIND=8) :: clz(2,2),cut,epsilon,svv

    
      
    this%n(1) = nx ; this%xst = xst ; this%xen = xen ;
    this%n(2) = ny ; this%yst = yst ; this%yen = yen ;
    this%n(3) = nz ; this%zst = zst ; this%zen = zen ;

    ! wavenumber in the direction-z := \varphi
    nxp = nx+1
    hx = x(2)-x(1)
    xmin = x(1)
    xmax = x(nx+1)+hx
    Lx = xmax-xmin 
    wx = (2*pi)/Lx
      
    nyp = ny+1
    hy = y(2)-y(1)
    ymin = y(1)
    ymax = y(ny+1)+hy
    Ly = ymax-ymin 
    wy = (2*pi)/Ly
    
    nzp = nz + 1
    
    allocate( r(1:nz+1,1:nz+1) , rm1(1:nz+1,1:nz+1) , rm2(1:nz+1,1:nz+1) )
    r = 0
    rm1 = 0
    rm2 = 0
    do i = 1 , nz+1
       r  (i,i) = z(i)
       rm1(i,i) = z(i)**(-1)
       rm2(i,i) = z(i)**(-2)
    end do
    
    
    allocate( pz  ( 1:nz+1 , 1:nz+1 , zst(1):zen(1) ) ) ; pz = 0
    allocate( pzm1( 1:nz+1 , 1:nz+1 , zst(1):zen(1) ) ) ; pzm1 = 0
    allocate( lbdz( 1:nz+1 ,          zst(1):zen(1) ) ) ; lbdz = 0 
    allocate( lbdz_( 1:nz+1 ,          zst(1):zen(1) ) ) ; lbdz_ = 0 
      
    allocate( flz ( 1:nz+1 ,          xst(1):xen(1) ) ) ; flz = 0
    allocate( frz ( 1:nz+1 ,          xst(1):xen(1) ) ) ; frz = 0
    allocate( ccz ( 1:2    , 1:nz+1                 ) ) ; ccz = 0

    
    allocate( id ( 1:nz+1 , 1:nz+1 ) ) ; id = 0
    allocate( d2 ( 1:nz+1 , 1:nz+1 ) ) ; d2 = 0
    allocate( bl ( 1:nz+1 , 1:nz+1 ) ) ; bl = 0
    allocate( br ( 1:nz+1 , 1:nz+1 ) ) ; br = 0
    
    
    id=0
    do i=1,nz+1
       id(i,i)=1
    end do
    d2 = 0

    this%nu=[nux,nuy,nuz]
    
    
    bl = cl_left_z(1) * id + cl_left_z(2) * dz
    br = cl_right_z(1) * id + cl_right_z(2) * dz

    !ajout de la svv à l'opératuer d2
    
!    allocate(M(1:nz+1,1:nz+1),T(1:nz+1,1:nz+1),Q(1:nz+1,1:nz+1),C(1:nz+1),SVV_TCHEBY(1:nz+1,1:nz+1))
!    C=1.
!    C(1)=2.
!    C(nz+1)=2.
    
!    do i=1,nz+1
!       do j=1,nz+1
!          M(I,J) = 2./REAL(nz) * cos(i*j*pi/nz) * 1/(c(i)*c(j))
!          T(I,J) =              cos(i*j*pi/nz)
!       end do
!    end do
      
!    cut = beta*SQRT(REAL(nz))
!    epsilon = alpha/REAL(nz)
!    Q=0.
!    DO k=1,nz
!       IF (k > cut) Q(k,k) =  EXP( - REAL(k-nz)**2/REAL(k-cut)**2 )
!    END DO

!    SVV_TCHEBY = MATMUL( T , epsilon * MATMUL(Q , M ) )

    epsilon = 2.*alpha/real(nx+1)
    cut = beta*sqrt(real(nx+1)/2.)
    
    do i = zst(1) , zen(1)
       k = abs(index_to_freq_c2c(i,nx+1))
       if ( k < cut ) then
          svv = 0.
       else
          svv = epsilon*exp(- (k - nx - 1.0 )**2/((k - cut)**2) )
       end if
       !write(6,'(2(i9),9(e15.8))')i,k,svv
       im = half_complex_wp(i,nx+1)
       d2 = nuz*( d2z +  matmul( rm1 , dz ) ) - (nux + svv) * (im*wx)**2 * rm2
       
       ! composantes :  ( 1 # azimuth , 2 # axial , 3 # radial )
       if ( (this%axis==1).or.(this%axis==3) ) then
          d2 = d2  -  nuz*rm2 !+ SVV_TCHEBY
       end if
       
       call reduction_operator_cplx( &
            d2, bl, br, pz(1:nzp,1:nzp,i), pzm1(1:nzp,1:nzp,i), lbdz_(1:nzp,i), & 
            clz, ccz, flz(1:nzp,1),frz(1:nzp,1), nz )
       
       
    end do
    
    allocate( this%pz  ( 1:nz+1 , 1:nz+1 , zst(1):zen(1) ) ) ; this%pz = pz
    allocate( this%pzm1( 1:nz+1 , 1:nz+1 , zst(1):zen(1) ) ) ; this%pzm1 = pzm1
    allocate( this%lbdz( 1:nz+1 ,          zst(1):zen(1) ) ) ; this%lbdz = lbdz_ 
    
    allocate( this%flz ( 1:nz+1 ,          xst(1):xen(1) ) ) ; this%flz = flz
    allocate( this%frz ( 1:nz+1 ,          xst(1):xen(1) ) ) ; this%frz = frz
    allocate( this%ccz ( 1:2    , 1:nz+1                 ) ) ; this%ccz = ccz
      
    this%clz = clz
    
    deallocate( d2,bl,br,id )
    
    allocate( this%lbdy( 1:ny+1 ) ); this%lbdy = 0

    epsilon = 2.*alpha/real(ny+1)
    cut = beta*sqrt(real(ny+1)/2.)
      
    do j = 1 , ny+1
       k = abs(index_to_freq_c2c(j, ny+1))
       if ( k < cut ) then
          svv = 0.
       else
          svv = epsilon*exp(- real((k - ny - 1 )**2)/real((k - cut)**2) )
       end if
       jm = half_complex_wp(j,ny+1)
       this%lbdy(j) = - (nuy + svv) * (jm*wy)**2
    end do
    
    allocate( this%lbdx( 1:nx+1 ) ); this%lbdx = 0
    allocate( this%bc_val_l_z ( xst(1):xen(1) , xst(2):xen(2) ) ) ; this%bc_val_l_z = 0
    allocate( this%bc_val_r_z ( xst(1):xen(1) , xst(2):xen(2) ) ) ; this%bc_val_r_z = 0


    if (.not.allocated(dg_cl_z)) then
       allocate( dg_cl_z(zst(1):zen(1),zst(2):zen(2),1:2 )  )
       allocate( LBD(zst(1):zen(1),zst(2):zen(2),zst(3):zen(3) ) )
    end if
    
  end subroutine solver_diag_hhi_build_svv


  
  subroutine solver_diag_hhi_set_boundary_field(x,y,z,udf_bc_left,udf_bc_right,bvzl,bvzr,xst,xen,yst,yen,zst,zen)
    use m_numerics
    implicit none
    integer :: xst(3),xen(3)
    integer :: yst(3),yen(3)
    integer :: zst(3),zen(3)
    
    real(kind=8), dimension(:),allocatable :: x,y,z
    real(kind=8), dimension(xst(1):xen(1),xst(2):xen(2)) :: bvzl
    real(kind=8), dimension(xst(1):xen(1),xst(2):xen(2)) :: bvzr
    PROCEDURE(UDF_TIMESPACE)      :: UDF_BC_LEFT
    PROCEDURE(UDF_TIMESPACE)      :: UDF_BC_RIGHT
    integer :: i,j
    integer :: nx,ny,nz,n(3)
    real(kind=8) :: zmin,zmax

    n = xen - xst
    nz = zen(3) - zst(3) + 1 - 1

    zmin = z(1)
    zmax = z(nz+1)
    
    forall(i=xst(1):xen(1),j=xst(2):xen(2))
       bvzl(i,j) = udf_bc_left(0d0,X(I),Y(J),ZMIN)
    end forall
    
    
    forall(i=xst(1):xen(1),j=xst(2):xen(2))
       bvzr(i,j) = udf_bc_right(0d0,X(I),Y(J),ZMAX)
    end forall

    
    
  end subroutine solver_diag_hhi_set_boundary_field


  subroutine solver_diag_hhi_set_unsteady_boundary_field(x,y,z,tc,udf_bc_left,udf_bc_right,bvzl,bvzr,xst,xen,yst,yen,zst,zen)
    use m_numerics
    implicit none
    integer :: xst(3),xen(3)
    integer :: yst(3),yen(3)
    integer :: zst(3),zen(3)
    real(kind=8) :: tc
    real(kind=8), dimension(:),allocatable :: x,y,z
    real(kind=8), dimension(xst(1):xen(1),xst(2):xen(2)) :: bvzl
    real(kind=8), dimension(xst(1):xen(1),xst(2):xen(2)) :: bvzr
    PROCEDURE(UDF_TIMESPACE)      :: UDF_BC_LEFT
    PROCEDURE(UDF_TIMESPACE)      :: UDF_BC_RIGHT
    integer :: i,j
    integer :: nx,ny,nz,n(3)
    real(kind=8) :: zmin,zmax

    n = xen - xst
    nz = zen(3) - zst(3) + 1
    
    zmin = z(1)
    zmax = z(nz+1)

    
    forall(i=xst(1):xen(1),j=xst(2):xen(2))
       bvzl(i,j) = udf_bc_left(tc,X(I),Y(J),ZMIN)
    end forall

    
    forall(i=xst(1):xen(1),j=xst(2):xen(2))
       bvzr(i,j) = udf_bc_right(tc,X(I),Y(J),ZMAX)
    end forall
    
    
  end subroutine solver_diag_hhi_set_unsteady_boundary_field
  
  subroutine solver_diag_cyl_hhi_solve(fi,sfi,sigma,&
